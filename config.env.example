# ============================================================
# term-app 配置模板
# 用法:  cp config.env.example config.env  然后填下面的值
# config.env 已被 .gitignore 忽略, 不会进仓库。
# 随机密钥用  ./gen-secrets.sh  生成。
# ============================================================

# 对外域名 (A 记录要指向本机公网 IP, 且未被 Cloudflare 代理)
DOMAIN="term.example.com"

# --- Google OAuth (Google Cloud Console 里的 OAuth client) ---
# 记得在该 client 的"已授权重定向 URI"里加:  https://<DOMAIN>/oauth2/callback
GOOGLE_CLIENT_ID="xxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxx"

# --- 两个随机密钥 (跑 ./gen-secrets.sh 生成后粘进来) ---
OAUTH2_COOKIE_SECRET=""     # 32 字节 base64
TOTP_GATE_HMAC_KEY=""       # 32 字节 hex

# cookie 有效期 (小时)
COOKIE_TTL_HOURS=72

# oauth2-proxy 下载版本
OAUTH2_PROXY_VERSION="v7.6.0"

# --- 用户映射 ---
# 每行一个用户, 用空格分隔 4 个字段:
#   "谷歌邮箱   unix用户名   ttyd端口   TOTP密钥(base32)"
# - 谷歌邮箱: 允许登录并映射到该 unix 用户的 Google 账号
# - unix用户名: 必须是本机已存在的用户, 网页终端 = 以该用户 ssh 的效果
# - ttyd端口: 127.0.0.1 上的本地端口, 各用户互不相同、别撞已用端口
# - TOTP密钥: ./gen-secrets.sh 生成, 扫进各自手机的 Aegis
USERS=(
  "someone@gmail.com   alan   7681   BASE32SECRETFORALAN"
  "another@gmail.com   mk     7682   BASE32SECRETFORMK"
)
